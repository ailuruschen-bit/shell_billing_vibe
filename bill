#!/usr/bin/env bash
# bill - a cute and practical CLI bookkeeping tool 🐷💰
#
# Design goals:
# - Bash only + common Unix tools (awk/date/mkdir)
# - Force bash via shebang (works even if your default shell is zsh)
# - Local storage by default: ~/.bill/ (override via BILL_HOME)
#
# Usage:
#   bill <+/-money> <comment...> [MM/dd]
#   bill mod <money>
#   bill show
#   bill show all
#   bill help | bill \? | bill --help

set -euo pipefail

# -------------------------
# Basic configuration (override via env vars)
# -------------------------
DATA_DIR="${BILL_HOME:-"$HOME/.bill"}"
BAL_FILE="$DATA_DIR/balance"
LEDGER_FILE="$DATA_DIR/ledger.tsv"
BIG_SPEND="${BILL_BIG_SPEND:-500}"   # big-spend warning threshold (default: 500)
SHOW_TAIL="${BILL_SHOW_TAIL:-10}"    # how many recent entries to show in `bill show`
LEDGER_HEADER=$'date\ttime\tamount\tcomment\tbalance\n'

# -------------------------
# Colors & cute output
# -------------------------
supports_color() {
  [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]
}

if supports_color; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_MAGENTA=$'\033[35m'
  C_CYAN=$'\033[36m'
else
  C_RESET=""; C_BOLD=""; C_DIM=""
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_MAGENTA=""; C_CYAN=""
fi

say() { printf "%b\n" "$*"; }

die() {
  say "${C_RED}${C_BOLD}Oops: ${C_RESET}${C_RED}$*${C_RESET}"
  say "${C_DIM}Tip: run ${C_BOLD}bill help${C_RESET}${C_DIM} (or ${C_BOLD}bill \\?${C_RESET}${C_DIM}) for usage.${C_RESET}"
  exit 1
}

random_pick() {
  # Pick one string randomly from args
  local count=$#
  (( count > 0 )) || return 0
  local idx=$(( RANDOM % count + 1 ))
  eval "printf '%s' \"\${$idx}\""
}

fmt_money() {
  # Always print as 2 decimals
  awk -v x="$1" 'BEGIN{printf "%.2f", x+0}'
}

is_number() {
  [[ "$1" =~ ^[-+]?[0-9]+([.][0-9]+)?$ ]]
}

is_signed_number() {
  # For entries we require an explicit + or -
  [[ "$1" =~ ^[+-][0-9]+([.][0-9]+)?$ ]]
}

ensure_data() {
  mkdir -p "$DATA_DIR"
  if [[ ! -f "$BAL_FILE" ]]; then
    printf "0\n" >"$BAL_FILE"
  fi

  # Ledger file: auto-create / auto-migrate legacy format (time/amount/comment/balance)
  if [[ ! -f "$LEDGER_FILE" ]]; then
    printf "%s" "$LEDGER_HEADER" >"$LEDGER_FILE"
    return 0
  fi

  local hdr
  IFS= read -r hdr <"$LEDGER_FILE" || hdr=""
  if [[ "$hdr" == $'time\tamount\tcomment\tbalance' ]]; then
    # Migrate legacy format to: date	time	amount	comment	balance
    local ts bak tmp
    ts="$(date "+%Y%m%d-%H%M%S")"
    bak="$LEDGER_FILE.bak-$ts"
    tmp="$LEDGER_FILE.tmp-$ts"
    cp "$LEDGER_FILE" "$bak" 2>/dev/null || true
    printf "%s" "$LEDGER_HEADER" >"$tmp"
    awk -F'\t' '
      NR==1{next}
      {
        # $1 = "YYYY-MM-DD HH:MM:SS"
        split($1, dt, " ")
        d = dt[1]
        t = (dt[2] ? dt[2] : "00:00:00")
        printf "%s\t%s\t%s\t%s\t%s\n", d, t, $2, $3, $4
      }
    ' "$LEDGER_FILE" >>"$tmp"
    mv "$tmp" "$LEDGER_FILE"
  fi
}

read_balance() {
  ensure_data
  local b
  b="$(<"$BAL_FILE")"
  is_number "$b" || b="0"
  fmt_money "$b"
}

write_balance() {
  ensure_data
  fmt_money "$1" >"$BAL_FILE"
}

append_ledger() {
  ensure_data
  local d t amt cmt bal
  d="$1"
  t="$2"
  amt="$3"
  cmt="$4"
  bal="$5"
  printf "%s\t%s\t%s\t%s\t%s\n" "$d" "$t" "$amt" "$cmt" "$bal" >>"$LEDGER_FILE"
}

is_mmdd() {
  [[ "$1" =~ ^(0[1-9]|1[0-2])/(0[1-9]|[12][0-9]|3[01])$ ]]
}

mmdd_to_ymd() {
  # Expand MM/dd with the current year -> YYYY-MM-DD
  local mmdd="$1"
  local y
  y="$(date "+%Y")"
  printf "%s-%s-%s" "$y" "${mmdd%/*}" "${mmdd#*/}"
}

join_by_space() {
  local out=""
  local part
  for part in "$@"; do
    if [[ -z "$out" ]]; then out="$part"; else out="$out $part"; fi
  done
  printf "%s" "$out"
}

recalc_balances() {
  # Recalculate the balance column for all rows + refresh balance file
  ensure_data
  local ts tmp
  ts="$(date "+%Y%m%d-%H%M%S")"
  tmp="$LEDGER_FILE.recalc-$ts"
  printf "%s" "$LEDGER_HEADER" >"$tmp"

  local bal="0"
  awk -F'\t' -v OFS='\t' '
    NR==1{next}
    {
      d=$1; t=$2; a=$3; c=$4; b=$5
      if(a=="MOD"){
        bal = b+0
      } else {
        bal = (bal+0) + (a+0)
      }
      printf "%s\t%s\t%s\t%s\t%.2f\n", d, t, a, c, bal
    }
  ' "$LEDGER_FILE" >>"$tmp"

  # Update total balance = last row's balance (or 0 if empty)
  local final
  final="$(awk -F'\t' 'NR==1{next} {x=$5} END{if(NR==1) x=0; printf "%.2f", x+0}' "$tmp")"
  mv "$tmp" "$LEDGER_FILE"
  write_balance "$final"
}

usage() {
  say "${C_CYAN}${C_BOLD}bill - CLI bookkeeping tool${C_RESET}  ${C_DIM}(data dir: $DATA_DIR)${C_RESET}"
  say ""
  say "${C_BOLD}Usage:${C_RESET}"
  say "  ${C_GREEN}bill <+/-money> <comment...> [MM/dd]${C_RESET}   Add an entry (e.g. bill -12.5 \"milk tea\" 05/13)"
  say "  ${C_YELLOW}bill mod <money>${C_RESET}                         Set total balance directly (e.g. bill mod 2000)"
  say "  ${C_BLUE}bill show${C_RESET}                                Summary + recent entries"
  say "  ${C_BLUE}bill show all${C_RESET}                            Monthly pager for all history (edit/delete)"
  say "  ${C_MAGENTA}bill help${C_RESET}                                Show help (recommended for zsh)"
  say "  ${C_MAGENTA}bill \\?${C_RESET}                                  Show help (? needs escaping in zsh)"
  say "  ${C_MAGENTA}bill doctor${C_RESET}                              Environment self-check"
  say ""
  say "${C_DIM}Tips: export BILL_BIG_SPEND=1000   # big-spend warning threshold${C_RESET}"
  say "${C_DIM}      export BILL_HOME=~/.mybill   # custom data dir${C_RESET}"
}

cheer_for_income() {
  random_pick \
    "Nice! ${C_GREEN}Income added${C_RESET} — one step closer to your goal." \
    "Cha-ching! ${C_GREEN}Money in${C_RESET}. Your wallet feels happier already." \
    "Great move — tracking income is a superpower."
}

comfort_for_spend_small() {
  random_pick \
    "Logged it ✅ Small spends count too — nice discipline." \
    "Spending isn't scary; untracked spending is. You're in control." \
    "Recorded! Keep stacking those savings steadily."
}

warn_for_big_spend() {
  random_pick \
    "Whoa… that's a big one. ${C_YELLOW}Do you really need it?${C_RESET} (Still: tracking wins!)" \
    "Wallet alert: ${C_RED}big spend detected${C_RESET}. Maybe do a quick review later." \
    "Bold purchase! Next time maybe wait for a discount — you got this."
}

pep_talk() {
  random_pick \
    "Saving isn't punishment — it's a gift to your future self." \
    "Tiny progress every day. Your balance will thank you." \
    "You're doing the coolest long-game thing: owning your cashflow."
}

cmd_add() {
  local amt="$1"; shift
  local d t cmt
  d="$(date "+%Y-%m-%d")"
  t="$(date "+%H:%M:%S")"

  # Supports: bill <+/-money> <comment...> [MM/dd]
  # Rule: if the last arg is MM/dd, treat it as date; the rest becomes comment
  local args=("$@")
  local argc="${#args[@]}"
  if (( argc == 0 )); then
    die "Please add a comment. Example: bill -18 lunch"
  fi
  if is_mmdd "${args[$((argc-1))]}"; then
    if (( argc == 1 )); then
      die "Comment cannot be empty. Example: bill -18 lunch 05/13"
    fi
    d="$(mmdd_to_ymd "${args[$((argc-1))]}")"
    cmt="$(join_by_space "${args[@]:0:$((argc-1))}")"
  else
    cmt="$(join_by_space "${args[@]}")"
  fi

  [[ -n "$cmt" ]] || die "Please add a comment. Example: bill -18 lunch"
  is_signed_number "$amt" || die "Amount must start with + or -. Examples: +100 or -12.5"

  local bal newbal absamt
  bal="$(read_balance)"
  newbal="$(awk -v b="$bal" -v a="$amt" 'BEGIN{printf "%.2f", b+a}')"
  write_balance "$newbal"
  append_ledger "$d" "$t" "$amt" "$cmt" "$newbal"

  absamt="$(awk -v a="$amt" 'BEGIN{a+=0; if(a<0)a=-a; printf "%.2f", a}')"

  if [[ "$amt" == +* ]]; then
    say "${C_GREEN}${C_BOLD}✔ Saved${C_RESET}  ${C_GREEN}${amt}${C_RESET}  ${C_DIM}(${cmt})${C_RESET}"
    say "$(cheer_for_income)"
  else
    # Expense: warn if it's big
    if awk -v a="$absamt" -v t="$BIG_SPEND" 'BEGIN{exit !(a>=t)}'; then
      say "${C_RED}${C_BOLD}✔ Saved${C_RESET}  ${C_RED}${amt}${C_RESET}  ${C_DIM}(${cmt})${C_RESET}"
      say "$(warn_for_big_spend)"
    else
      say "${C_YELLOW}${C_BOLD}✔ Saved${C_RESET}  ${C_YELLOW}${amt}${C_RESET}  ${C_DIM}(${cmt})${C_RESET}"
      say "$(comfort_for_spend_small)"
    fi
  fi

  say "${C_CYAN}Current balance: ${C_BOLD}$(fmt_money "$newbal")${C_RESET} ${C_DIM}(keep going!)${C_RESET}"
}

cmd_mod() {
  local m="${1:-}"
  [[ -n "$m" ]] || die "Usage: bill mod <money>  e.g. bill mod 2000"
  is_number "$m" || die "Balance must be a number, e.g. 2000 or 1999.5"

  local newbal oldbal d t
  d="$(date "+%Y-%m-%d")"
  t="$(date "+%H:%M:%S")"
  oldbal="$(read_balance)"
  newbal="$(fmt_money "$m")"
  write_balance "$newbal"
  append_ledger "$d" "$t" "MOD" "Manual balance override" "$newbal"

  say "${C_MAGENTA}${C_BOLD}✿ Balance updated${C_RESET}  ${C_DIM}${oldbal} → ${C_BOLD}${newbal}${C_RESET}"
  say "$(pep_talk)"
}

cmd_show() {
  ensure_data
  local bal
  bal="$(read_balance)"

  # Summary stats
  local stats
  stats="$(awk -F'\t' '
    NR==1{next}
    $3=="MOD"{next}
    {
      a=$3+0
      if (a>=0) { inc = inc + a } else { spend = spend + (-a) }
      n++
    }
    END{
      if(n==0){inc=0; spend=0}
      printf "%.2f\t%.2f\t%d\n", inc, spend, n
    }
  ' "$LEDGER_FILE")"
  local inc spend n
  inc="$(cut -f1 <<<"$stats")"
  spend="$(cut -f2 <<<"$stats")"
  n="$(cut -f3 <<<"$stats")"

  # Same box renderer as `show all` (fixes alignment for CJK characters)
  printf "%b" "${C_CYAN}${C_BOLD}"; box_top; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Wallet dashboard"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Current balance: $(fmt_money "$bal")"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Total income:    $(fmt_money "$inc")"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Total spend:     $(fmt_money "$spend")"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Entries:         ${n}"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_bottom; printf "%b" "${C_RESET}"

  say "$(pep_talk)"
  say ""
  say "${C_BOLD}Recent ${SHOW_TAIL}:${C_RESET}"

  # Print recent entries (no header) with basic coloring
  awk -F'\t' -v N="$SHOW_TAIL" -v cr="$C_RED" -v cg="$C_GREEN" -v cy="$C_YELLOW" -v cd="$C_DIM" -v cb="$C_BOLD" -v ce="$C_RESET" '
    NR==1{next}
    {lines[NR]=$0; count++}
    END{
      start = (count-N+2); if(start<2) start=2
      for(i=start; i<=count+1; i++){
        split(lines[i], f, "\t")
        d=f[1]; tt=f[2]; a=f[3]; c=f[4]; b=f[5]
        stamp = d " " tt
        if(a=="MOD"){
          printf "%s•%s %s%s%s  %s%s%s  %s(balance=%s)%s  %s\n", cd, ce, cb, "[MOD]", ce, cd, stamp, ce, cd, b, ce, c
        } else if((a+0)>=0){
          v=a+0
          printf "%s•%s %s+%.2f%s  %s%s%s  %s(balance=%s)%s  %s\n", cd, ce, cg, v, ce, cd, stamp, ce, cd, b, ce, c
        } else {
          v=a+0
          printf "%s•%s %s%.2f%s  %s%s%s  %s(balance=%s)%s  %s\n", cd, ce, cy, v, ce, cd, stamp, ce, cd, b, ce, c
        }
      }
    }
  ' "$LEDGER_FILE"
}

clear_screen() {
  # Portable clear (no dependency on `clear`)
  printf "\033[2J\033[H"
}

pause_any_key() {
  say "${C_DIM}(press any key to continue...)${C_RESET}"
  read -rsn1 _ || true
}

repeat_char() {
  # repeat_char "─" 10
  local ch="$1"
  local n="$2"
  local out=""
  local i
  for ((i=0; i<n; i++)); do out+="$ch"; done
  printf "%s" "$out"
}

BOX_INNER_WIDTH="${BILL_BOX_WIDTH:-56}"  # box inner width in terminal columns (approx)

pad_to_width() {
  # Read one line from stdin, output a string padded/truncated to display-width = w.
  # Uses python3 + East Asian Width to fix CJK alignment.
  local w="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 -c '
import sys, unicodedata
w = int(sys.argv[1])
s = sys.stdin.read().rstrip("\n")

def cw(ch: str) -> int:
    return 2 if unicodedata.east_asian_width(ch) in ("W","F") else 1

def disp_width(t: str) -> int:
    return sum(cw(ch) for ch in t)

ellipsis = "…"
out = ""
cur = 0
for ch in s:
    c = cw(ch)
    if cur + c > w:
        break
    out += ch
    cur += c

if disp_width(s) > w and w > 0:
    e = cw(ellipsis)
    if e <= w:
        while cur + e > w and out:
            last = out[-1]
            out = out[:-1]
            cur -= cw(last)
        out += ellipsis
        cur += e

pad = max(0, w - cur)
sys.stdout.write(out + (" " * pad))
' "$w"
  else
    # Fallback: no CJK width handling
    local text
    IFS= read -r text || text=""
    printf "%-*s" "$w" "$text"
  fi
}

box_line() {
  # box_line "text" -> "│ text(padded) │"
  local text="$1"
  local w="$BOX_INNER_WIDTH"
  local padded
  padded="$(printf "%s" "$text" | pad_to_width "$w")"
  printf "│ %s │\n" "$padded"
}

box_top() {
  local w="$BOX_INNER_WIDTH"
  printf "╭%s╮\n" "$(repeat_char "─" $((w + 2)))"
}

box_bottom() {
  local w="$BOX_INNER_WIDTH"
  printf "╰%s╯\n" "$(repeat_char "─" $((w + 2)))"
}

get_months_sorted() {
  # Print unique months (YYYY-MM), sorted lexicographically (same as chronological)
  # shellcheck disable=SC2016
  awk -F'\t' 'NR==1{next} {print substr($1,1,7)}' "$LEDGER_FILE" | sort -u
}

render_month_page() {
  local month="$1"

  # Collect records for this month (also keep source line number for edit/delete)
  local records
  records="$(awk -F'\t' -v m="$month" '
    NR==1{next}
    index($1, m)==1 { printf "%d\t%s\t%s\t%s\t%s\t%s\n", NR, $1, $2, $3, $4, $5 }
  ' "$LEDGER_FILE")"

  local -a srcn dates times amts cmts bals
  srcn=(); dates=(); times=(); amts=(); cmts=(); bals=()

  local line
  while IFS=$'\t' read -r nr d tt a c b; do
    [[ -n "${nr:-}" ]] || continue
    srcn+=("$nr"); dates+=("$d"); times+=("$tt"); amts+=("$a"); cmts+=("$c"); bals+=("$b")
  done <<<"$records"

  # Monthly stats
  local mstats
  mstats="$(awk -F'\t' -v m="$month" '
    NR==1{next}
    index($1, m)!=1 {next}
    $3=="MOD"{next}
    {
      a=$3+0
      if(a>=0){inc=inc+a}else{sp=sp+(-a)}
      n++
    }
    END{ if(n==0){inc=0;sp=0;n=0} printf "%.2f\t%.2f\t%.2f\t%d\n", inc, sp, (inc-sp), n }
  ' "$LEDGER_FILE")"
  local inc sp net cnt
  inc="$(cut -f1 <<<"$mstats")"
  sp="$(cut -f2 <<<"$mstats")"
  net="$(cut -f3 <<<"$mstats")"
  cnt="$(cut -f4 <<<"$mstats")"

  # Fixed-width box (alignment-safe)
  printf "%b" "${C_CYAN}${C_BOLD}"; box_top; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "${month} monthly statement"; printf "%b" "${C_RESET}"
  # Do not embed color control codes inside box_line text (would break width calculation)
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Income: $(fmt_money "$inc")  Spend: $(fmt_money "$sp")  Net: $(fmt_money "$net")"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_line "Entries: ${cnt}"; printf "%b" "${C_RESET}"
  printf "%b" "${C_CYAN}${C_BOLD}"; box_bottom; printf "%b" "${C_RESET}"
  printf "\n"

  # Table header
  printf "%b\n" "${C_BOLD}#   Date        Time      Amount      Balance      Comment${C_RESET}"
  printf "%b\n" "${C_DIM}----------------------------------------------------------------${C_RESET}"

  local i a
  for ((i=0; i<${#srcn[@]}; i++)); do
    local idx datev timev amt bal cmt color
    idx=$((i+1))
    datev="${dates[$i]}"
    timev="${times[$i]}"
    amt="${amts[$i]}"
    bal="${bals[$i]}"
    cmt="${cmts[$i]}"
    local amt_disp=""

    # Truncate very long comments to keep the table readable
    if (( ${#cmt} > 28 )); then
      cmt="${cmt:0:27}…"
    fi

    if [[ "$amt" == "MOD" ]]; then
      color="$C_MAGENTA"
      printf "%b%-3s %-10s  %-8s  %-10s  %-12s  %s%b\n" \
        "$color" "$idx" "$datev" "$timev" "[MOD]" "$(fmt_money "$bal")" "$cmt" "$C_RESET"
    else
      if awk -v x="$amt" 'BEGIN{exit !((x+0)>=0)}'; then
        amt_disp="+$(fmt_money "$amt")"
        color="$C_GREEN"
        printf "%b%-3s %-10s  %-8s  %-10s  %-12s  %s%b\n" \
          "$color" "$idx" "$datev" "$timev" "$amt_disp" "$(fmt_money "$bal")" "$cmt" "$C_RESET"
      else
        amt_disp="$(fmt_money "$amt")"
        color="$C_YELLOW"
        printf "%b%-3s %-10s  %-8s  %-10s  %-12s  %s%b\n" \
          "$color" "$idx" "$datev" "$timev" "$amt_disp" "$(fmt_money "$bal")" "$cmt" "$C_RESET"
      fi
    fi
  done

  say ""
  say "${C_DIM}Keys:${C_RESET} [n]next  [p]prev  [e]edit  [d]delete  [q]quit  [?]help"
}

ledger_delete_src_line() {
  local target="$1"
  [[ -n "$target" ]] || return 1
  local ts tmp
  ts="$(date "+%Y%m%d-%H%M%S")"
  tmp="$LEDGER_FILE.del-$ts"
  awk -v t="$target" 'NR==t{next} {print}' "$LEDGER_FILE" >"$tmp"
  mv "$tmp" "$LEDGER_FILE"
  recalc_balances
}

ledger_edit_src_line() {
  local target="$1"
  local new_amt="$2"
  local new_cmt="$3"
  local new_date="${4:-}"

  [[ -n "$target" ]] || return 1
  is_signed_number "$new_amt" || die "Edit failed: amount must start with + or - (e.g. +88 or -12.5)"
  [[ -n "$new_cmt" ]] || die "Edit failed: comment cannot be empty."
  if [[ -n "$new_date" ]] && ! is_mmdd "$new_date"; then
    die "Edit failed: date must be MM/dd (e.g. 05/13)"
  fi

  local ts tmp
  ts="$(date "+%Y%m%d-%H%M%S")"
  tmp="$LEDGER_FILE.edit-$ts"

  awk -F'\t' -v OFS='\t' -v t="$target" -v na="$new_amt" -v nc="$new_cmt" -v nd="$new_date" '
    NR==1{print; next}
    NR!=t{print; next}
    {
      d=$1; tt=$2; a=$3; c=$4; b=$5
      if(a=="MOD"){
        # Do not allow editing MOD rows for now (keeps balance logic sane)
        print $0
        next
      }
      if(nd!=""){
        split(nd, mmdd, "/")
        y=strftime("%Y")
        d = y "-" mmdd[1] "-" mmdd[2]
      }
      print d, tt, na, nc, b
    }
  ' "$LEDGER_FILE" >"$tmp"

  mv "$tmp" "$LEDGER_FILE"
  recalc_balances
}

cmd_show_all() {
  ensure_data

  # Month list (sorted by YYYY-MM)
  local months_raw
  months_raw="$(get_months_sorted)"
  local -a months=()
  local m
  while IFS= read -r m; do
    [[ -n "$m" ]] && months+=("$m")
  done <<<"$months_raw"

  if (( ${#months[@]} == 0 )); then
    say "${C_YELLOW}${C_BOLD}No entries yet.${C_RESET} Try: bill +10 \"pocket money\""
    return 0
  fi

  local idx=$(( ${#months[@]} - 1 ))  # start at the newest month

  while true; do
    clear_screen
    local cur="${months[$idx]}"
    render_month_page "$cur"
    say "${C_DIM}Page: $((idx+1))/${#months[@]} (higher = newer)${C_RESET}"
    printf "%b" "${C_BOLD}Choose an action key: ${C_RESET}"
    local key=""
    read -rsn1 key || true
    say ""

    case "$key" in
      "q")
        break
        ;;
      "n")
        if (( idx < ${#months[@]} - 1 )); then
          idx=$((idx+1))
        fi
        ;;
      "p")
        if (( idx > 0 )); then
          idx=$((idx-1))
        fi
        ;;
      "?")
        say "${C_CYAN}${C_BOLD}Help${C_RESET}"
        say "  - This is a monthly pager for your ledger."
        say "  - [e] Edit: press e, enter a row number, then input \"<+/-> <comment...> [MM/dd]\"."
        say "  - [d] Delete: press d, enter a row number (balances will be recalculated)."
        pause_any_key
        ;;
      "d")
        say "${C_YELLOW}${C_BOLD}Delete mode${C_RESET}: enter the row number on this page (starting from 1)"
        printf "%b" "${C_BOLD}Row #: ${C_RESET}"
        local num=""
        read -r num || true
        if [[ ! "$num" =~ ^[0-9]+$ ]]; then
          say "${C_RED}Row number must be a number.${C_RESET}"
          pause_any_key
          continue
        fi
        # Rebuild mapping for this month (avoid drift after edits/deletes)
        local map
        map="$(awk -F'\t' -v m="$cur" '
          NR==1{next}
          index($1,m)==1 {print NR}
        ' "$LEDGER_FILE")"
        local -a maparr=()
        while IFS= read -r line; do
          [[ -n "$line" ]] && maparr+=("$line")
        done <<<"$map"
        if (( num < 1 || num > ${#maparr[@]} )); then
          say "${C_RED}Out of range. Valid rows: 1..${#maparr[@]}${C_RESET}"
          pause_any_key
          continue
        fi
        local target="${maparr[$((num-1))]}"
        local kind
        kind="$(awk -F'\t' -v t="$target" 'NR==t{print $3}' "$LEDGER_FILE")"
        if [[ "$kind" == "MOD" ]]; then
          say "${C_RED}This is a MOD (balance override) row. Deleting is disabled.${C_RESET}"
          pause_any_key
          continue
        fi
        ledger_delete_src_line "$target"
        # Refresh month list (deleting might empty a month)
        months_raw="$(get_months_sorted)"
        months=(); while IFS= read -r m; do [[ -n "$m" ]] && months+=("$m"); done <<<"$months_raw"
        if (( ${#months[@]} == 0 )); then
          say "${C_GREEN}All cleared. Fresh starts can be awesome.${C_RESET}"
          break
        fi
        if (( idx >= ${#months[@]} )); then idx=$(( ${#months[@]} - 1 )); fi
        say "${C_GREEN}${C_BOLD}Deleted ✅${C_RESET} (balances recalculated)"
        pause_any_key
        ;;
      "e")
        say "${C_CYAN}${C_BOLD}Edit mode${C_RESET}: enter the row number on this page (starting from 1)"
        printf "%b" "${C_BOLD}Row #: ${C_RESET}"
        local num=""
        read -r num || true
        if [[ ! "$num" =~ ^[0-9]+$ ]]; then
          say "${C_RED}Row number must be a number.${C_RESET}"
          pause_any_key
          continue
        fi
        local map
        map="$(awk -F'\t' -v m="$cur" '
          NR==1{next}
          index($1,m)==1 {print NR}
        ' "$LEDGER_FILE")"
        local -a maparr=()
        while IFS= read -r line; do
          [[ -n "$line" ]] && maparr+=("$line")
        done <<<"$map"
        if (( num < 1 || num > ${#maparr[@]} )); then
          say "${C_RED}Out of range. Valid rows: 1..${#maparr[@]}${C_RESET}"
          pause_any_key
          continue
        fi

        local target="${maparr[$((num-1))]}"
        local kind
        kind="$(awk -F'\t' -v t="$target" 'NR==t{print $3}' "$LEDGER_FILE")"
        if [[ "$kind" == "MOD" ]]; then
          say "${C_RED}This is a MOD (balance override) row. Editing is disabled.${C_RESET}"
          pause_any_key
          continue
        fi
        # Show original row
        local old
        old="$(awk -F'\t' -v t="$target" 'NR==t{printf "%s %s %s %s\n",$1,$2,$3,$4}' "$LEDGER_FILE")"
        say "${C_DIM}Original: ${old}${C_RESET}"
        say "${C_CYAN}Enter new content (format: <+/-> <comment...> [MM/dd])${C_RESET}"
        say "${C_DIM}Example: -35.5 dinner 05/13${C_RESET}"
        printf "%b" "${C_BOLD}New: ${C_RESET}"
        local input=""
        IFS= read -r input || true
        if [[ -z "$input" ]]; then
          say "${C_YELLOW}Empty input — cancelled.${C_RESET}"
          pause_any_key
          continue
        fi
        # Parse input
        local -a arr=()
        read -r -a arr <<<"$input"
        local new_amt="${arr[0]:-}"
        local new_date=""
        local new_cmt=""
        if (( ${#arr[@]} < 2 )); then
          say "${C_RED}Invalid format. Need at least amount + comment.${C_RESET}"
          pause_any_key
          continue
        fi
        if is_mmdd "${arr[$((${#arr[@]}-1))]}"; then
          new_date="${arr[$((${#arr[@]}-1))]}"
          new_cmt="$(join_by_space "${arr[@]:1:$((${#arr[@]}-2))}")"
        else
          new_cmt="$(join_by_space "${arr[@]:1}")"
        fi
        ledger_edit_src_line "$target" "$new_amt" "$new_cmt" "$new_date"
        # Refresh month list (editing date might move rows across months)
        months_raw="$(get_months_sorted)"
        months=(); while IFS= read -r m; do [[ -n "$m" ]] && months+=("$m"); done <<<"$months_raw"
        if (( idx >= ${#months[@]} )); then idx=$(( ${#months[@]} - 1 )); fi
        say "${C_GREEN}${C_BOLD}Updated ✅${C_RESET} (balances recalculated)"
        pause_any_key
        ;;
      *)
        # Ignore other keys
        ;;
    esac
  done
}

cmd_doctor() {
  say "${C_CYAN}${C_BOLD}╭─ bill environment check ────────────────╮${C_RESET}"
  say "${C_CYAN}${C_BOLD}│${C_RESET} bill path:   ${C_BOLD}$0${C_RESET}"
  say "${C_CYAN}${C_BOLD}│${C_RESET} current shell:${C_BOLD}${SHELL:-unknown}${C_RESET}"
  say "${C_CYAN}${C_BOLD}│${C_RESET} bash version:${C_BOLD}${BASH_VERSION:-not in bash}${C_RESET}"
  say "${C_CYAN}${C_BOLD}│${C_RESET} bash path:   ${C_BOLD}$(command -v bash 2>/dev/null || printf "not found")${C_RESET}"
  say "${C_CYAN}${C_BOLD}│${C_RESET} awk path:    ${C_BOLD}$(command -v awk 2>/dev/null || printf "not found")${C_RESET}"
  say "${C_CYAN}${C_BOLD}│${C_RESET} data dir:    ${C_BOLD}${DATA_DIR}${C_RESET}"
  if [[ -f "$BAL_FILE" ]]; then
    say "${C_CYAN}${C_BOLD}│${C_RESET} balance file:${C_DIM} exists${C_RESET} (${BAL_FILE})"
  else
    say "${C_CYAN}${C_BOLD}│${C_RESET} balance file:${C_YELLOW} missing${C_RESET} (normal on first run)"
  fi
  if [[ -f "$LEDGER_FILE" ]]; then
    say "${C_CYAN}${C_BOLD}│${C_RESET} ledger file: ${C_DIM}exists${C_RESET} (${LEDGER_FILE})"
  else
    say "${C_CYAN}${C_BOLD}│${C_RESET} ledger file: ${C_YELLOW}missing${C_RESET} (normal on first run)"
  fi
  say "${C_CYAN}${C_BOLD}╰────────────────────────────────────────╯${C_RESET}"
  say "${C_DIM}Note: in zsh, '?' is a glob. Use: bill \\?  or  bill help${C_RESET}"
}

main() {
  # Even if launched from zsh, the shebang forces bash.
  # The check below is just a friendly hint (should rarely trigger).
  if [[ -z "${BASH_VERSION:-}" ]]; then
    say "${C_YELLOW}${C_BOLD}Note:${C_RESET}${C_YELLOW} not running in bash. Try: bash bill ...${C_RESET}"
  fi

  local cmd="${1:-}"
  case "$cmd" in
    ""|"?"|"help"|"-h"|"--help")
      usage
      ;;
    "show")
      if [[ "${2:-}" == "all" ]]; then
        cmd_show_all
      else
        cmd_show
      fi
      ;;
    "mod")
      shift
      cmd_mod "${1:-}"
      ;;
    "doctor")
      cmd_doctor
      ;;
    *)
      # Default: bill <+/-money> <comment...> [MM/dd]
      local amt="$1"
      shift || true
      cmd_add "$amt" "$@"
      ;;
  esac
}

main "$@"
